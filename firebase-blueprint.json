{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "distributors": {
          "type": "string",
          "description": "JSON stringified array of distributors"
        },
        "currency": {
          "type": "string",
          "description": "JSON stringified currency object"
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/UserProfile"
      },
      "description": "User profiles"
    }
  }
}
